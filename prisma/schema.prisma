// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String    @unique
  emailVerified       DateTime?
  image               String?
  password            String?
  role                String    @default("user")
  level               UserLevel @default(Beginner)
  topics              String?
  nativeLanguage      String    @default("English")
  goals               String?
  dailyGoal           Int?      @default(15) // e.g., time in minutes
  onboarded           Boolean   @default(false)
  wordOfTheDayStopped Boolean   @default(false)
  resetToken          String?
  resetTokenExpiry    DateTime?
  createdAt           DateTime  @default(now())

  words         Word[]
  reviews       WordReview[]
  quizzes       QuizQuestion[]
  studySessions StudySession[]
  accounts      Account[]
  sessions      Session[]
  quiz          Quiz[]
  notes         Note[]
  talks         TalkSession[]
  settings      UserSettings?
  notifications Notification[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime @db.Timestamp(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

enum UserLevel {
  Beginner
  Intermediate
  Advanced
}

model Word {
  id               String       @id @default(cuid())
  word             String       @unique
  type             WordType     @default(Word)
  userId           String
  user             User         @relation(fields: [userId], references: [id])
  masteryLevel     MasteryLevel
  audioUrl         String?
  tags             String?
  highlighted      Boolean      @default(false)
  isOriginal       Boolean      @default(false)
  proficiencyScore Int          @default(0)
  lastReviewedAt   DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  meanings WordMeaning[]
  reviews  WordReview[]
  quizzes  QuizQuestion[] @relation("WordToQuizQuestion")
}

enum WordType {
  Word
  Phrase
}

enum MasteryLevel {
  New
  Learning
  Familiar
  Mastered
}

model WordMeaning {
  id            String           @id @default(cuid())
  wordId        String
  word          Word             @relation(fields: [wordId], references: [id])
  definition    String
  guideWord     String?
  pronunciation String?
  cefrLevel     DifficultyLevel?
  partOfSpeech  String?
  examples      String[]         @default([])
  synonyms      String?
  antonyms      String?
  usageNotes    String?
}

enum DifficultyLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

model QuizQuestion {
  id String @id @default(cuid())

  userId     String
  user       User         @relation(fields: [userId], references: [id])
  direction  String
  question   String
  type       QuestionType
  options    String[]     @default([])
  gapHint    String?
  leftItems  String[]     @default([])
  rightItems String[]     @default([])
  answer     String?
  createdAt  DateTime     @default(now())

  // Many-to-many relationship with Word
  words Word[] @relation("WordToQuizQuestion")

  quizAnswers QuizAnswer[]
}

model Quiz {
  id                 String     @id @default(cuid())
  userId             String
  user               User       @relation(fields: [userId], references: [id])
  durationSeconds    Int
  totalWords         Int        @default(0)
  totalQuestions     Int        @default(0)
  completedQuestions Int        @default(0)
  unreachedQuestions Int        @default(0)
  skippedQuestions   Int        @default(0)
  correctAnswers     Int        @default(0)
  wrongAnswers       Int        @default(0)
  createdAt          DateTime   @default(now())
  completedAt        DateTime?
  status             QuizStatus @default(InProgress)

  quizAnswers QuizAnswer[]
}

model QuizAnswer {
  id                  String       @id @default(cuid())
  quizQuestionId      String
  quizQuestion        QuizQuestion @relation(fields: [quizQuestionId], references: [id])
  quizId              String
  quiz                Quiz         @relation(fields: [quizId], references: [id])
  userAnswer          String?
  isCorrect           Boolean?     @default(false)
  isWrong             Boolean?     @default(false)
  isSkipped           Boolean?     @default(false)
  isUnreached         Boolean?     @default(true)
  createdAt           DateTime     @default(now())
  retried             Boolean      @default(false)
  userAnswerRetry     String?
  isCorrectAfterRetry Boolean?     @default(false)

  @@unique([quizQuestionId, quizId])
}

enum QuizStatus {
  Perfect
  InProgress
  NeedsReview
  Excellent
}

enum QuestionType {
  DefinitionToWord_Typing
  WordToSynonym
  Matching
  FillInTheBlank
}

model WordReview {
  id             String        @id @default(cuid())
  wordId         String
  word           Word          @relation(fields: [wordId], references: [id])
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  createdAt      DateTime      @default(now())
  studySessionId String?
  studySession   StudySession? @relation(fields: [studySessionId], references: [id])

  scheduledAt  DateTime
  completedAt  DateTime?
  intervalDays Int
  performance  ReviewPerformance?
}

model StudySession {
  id                 String       @id @default(cuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id])
  completedAt        DateTime?
  durationSeconds    Int
  wordsReviewedCount Int?
  reviews            WordReview[]

  @@index([userId])
}

model Note {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String?
  content     String
  tags        String?
  highlighted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model TalkSession {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime      @default(now())
  messages  TalkMessage[]
}

model TalkMessage {
  id                  String      @id @default(cuid())
  sessionId           String
  session             TalkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role                String // "user" or "assistant"
  content             String      @db.Text
  refinement          String?     @db.Text
  explanation         String?     @db.Text
  evaluation          String?     @db.Text
  speakingSuggestions String[]    @default([])
  createdAt           DateTime    @default(now())
}

enum ReviewPerformance {
  Forgot
  Hard
  Medium
  Good
  Easy
}

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 1. Review settings
  wordsPerReview           Int             @default(10)
  reviewFrequency          ReviewFrequency @default(Daily)
  reviewReminderTime       String?         @default("08:00 PM")
  reviewDays               DayOfWeek[]     @default([Monday, Tuesday, Wednesday, Thursday, Friday, Saturday, Sunday])
  includeWordLevels        MasteryLevel[]  @default([New, Learning, Familiar, Mastered])
  prioritizeWeakWords      Boolean         @default(true)
  autoRepeatForgottenWords Boolean         @default(true)

  // 2. Quiz settings
  questionsPerQuiz         Int            @default(10)
  quizTypes                QuestionType[] @default([DefinitionToWord_Typing, WordToSynonym, Matching, FillInTheBlank])
  quizWordLevels           MasteryLevel[] @default([Learning, Familiar, Mastered])
  timeLimitPerQuestion     Int            @default(0) // 0 means no limit, otherwise seconds per question
  showResultsMode          QuizResultMode @default(AtTheEnd)
  allowRetry               Boolean        @default(true)
  includeAudioQuestions    Boolean        @default(true)
  includeFirstLetterInHint Boolean        @default(true)

  // 3. Learning preference settings
  showIpaPronunciation  Boolean @default(true)
  autoPlayPronunciation Boolean @default(false)
  dailyNewWordsGoal     Int     @default(5)

  // 4. Spaced repetition settings
  reviewAlgorithm   SpacedRepetitionAlgorithm @default(Default)
  forgottenInterval Int                       @default(1) // days
  hardInterval      Int                       @default(2) // days
  mediumInterval    Int                       @default(3) // days 
  goodInterval      Int                       @default(5) // days
  easyInterval      Int                       @default(8) // days

  // 5. Notification settings
  dailyReminderEnabled        Boolean @default(true)
  notificationTime            String  @default("07:30 PM")
  missedReviewReminderEnabled Boolean @default(true)
  streakReminderEnabled       Boolean @default(true)
  wordOfTheDayEnabled         Boolean @default(true)

  timezone String @default("UTC") // Store user's preferred timezone
}

enum ReviewFrequency {
  Daily
  Every2Days
  Custom
}

enum DayOfWeek {
  Monday
  Tuesday
  Wednesday
  Thursday
  Friday
  Saturday
  Sunday
}

enum QuizResultMode {
  AfterEachQuestion
  AtTheEnd
}

enum SpacedRepetitionAlgorithm {
  Default
  Custom
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}
